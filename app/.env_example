# Optional: runtime environment
# FLASK_ENV=production

# Optional: container timezone (defaults to UTC when unset).
# TZ=UTC

# Optional: container cron toggle.
# true (default): start crond for scheduled jobs
# false: skip crond startup (use external scheduler/platform jobs)
ENABLE_CRON=true

# Optional: Database URL (defaults to SQLite at app/data/db.sqlite)
DATABASE_URL=sqlite:///app/data/db.sqlite

# APP_SECRET is used to encrypt/decrypt email passwords, TOTP secrets,
# and OpenAI API keys stored in the database.
# Generate a strong random value, e.g.: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# WARNING: Changing this value will make existing encrypted values unreadable.
APP_SECRET=

# SECRET_KEY protects Flask session cookies. Set a stable value so sessions
# survive application restarts. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Optional: set to false for local HTTP development only.
# Keep true in production behind HTTPS.
SESSION_COOKIE_SECURE=true

# Optional: configure Flask-Limiter storage backend.
# Defaults to in-memory storage (suitable for single-process deployments).
# For multi-process/multi-server deployments, use a Redis URL, e.g.:
#   RATELIMIT_STORAGE_URI=redis://localhost:6379/0
RATELIMIT_STORAGE_URI=memory://

# Optional: Gunicorn worker process count.
# If unset, startup auto-selects workers based on CPU and rate-limit backend.
GUNICORN_WORKERS=

# Optional: Gunicorn worker timeout in seconds (defaults to 120).
GUNICORN_TIMEOUT=120

# Optional: create the initial global admin on first startup instead of relying
# on the signup form. Remove or leave blank after the account is created.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Optional: subscription enforcement toggle.
# true: require active subscription for non-global-admin users.
# false: bypass subscription checks (self-hosted/manual mode).
PAYMENTS_ENABLED=false

# Required for payment-created user onboarding links (Stripe/App Store flows).
# Must be a full origin/base URL (e.g., https://app.example.com).
FRONTEND_BASE_URL=

# Optional: password setup token expiration for payment-created users.
# Defaults to 60 minutes.
PASSWORD_SETUP_TOKEN_TTL_MINUTES=60

# Optional: Stripe webhook signing secret (required for Stripe webhook validation).
STRIPE_WEBHOOK_SECRET=

# Optional: local/dev-only toggle to allow App Store stub verification.
# Keep disabled in production.
APPSTORE_ALLOW_STUB_VERIFICATION=false

# Required for real App Store Server API verification.
APPLE_ISSUER_ID=
APPLE_KEY_ID=
# Provide either inline key or a file path.
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=
# Recommended verification guard.
APPLE_BUNDLE_ID=
# production | sandbox | auto
APPLE_ENVIRONMENT=production

# Optional (required to enable Passkey / WebAuthn authentication):
# RP ID should match your effective domain (e.g., app.example.com).
# RP Name is user-facing and shown by authenticators.
# Origin must exactly match scheme + host (+port in local dev).
PASSKEY_RP_ID=
PASSKEY_RP_NAME=PyCashFlow
PASSKEY_ORIGIN=

# Optional: DigitalOcean GenAI Agent endpoint settings.
# When both are set, AI insights can use the DO provider via OpenAI-compatible API.
DO_AI_BASE_URL=
DO_AI_API_KEY=

# Optional (legacy integrations)
API_SECRET=
PROJECT_ID=
FRONTEND_URI=

# Optional: fallback app version string when DOCKER_TAG is not set.
APP_VERSION=

# Optional: custom log file path for getemail job logging.
GETEMAIL_LOG_FILE=
